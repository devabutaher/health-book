generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum PostPrivacy {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum HealthLogType {
  ROUTINE
  GOAL
  WORKOUT
  MOOD
  QUICK
}

enum ReactionType {
  INSPIRED
  CLAP
  KEEP_IT_UP
  HEALING
  LOVE
  FIRE
  STRONG
  HUNDRED
}

enum NotificationType {
  NEW_FOLLOWER
  POST_REACTION
  POST_COMMENT
  COMMENT_REPLY
  MENTION
  MESSAGE
  CHALLENGE_INVITE
  CONSULTATION_BOOKED
  STREAK_MILESTONE
  STREAK_AT_RISK
  CHECK_IN_REMINDER
  CHALLENGE_ENDING_SOON
  SYSTEM
}

enum GroupType {
  PUBLIC
  PRIVATE
  SECRET
}

enum GroupRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum ChallengeType {
  SOLO
  GROUP
  PLATFORM
  DUEL
}

enum ChallengeDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ChallengeCategory {
  FITNESS
  NUTRITION
  MENTAL_HEALTH
  SLEEP
  GENERAL
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  username   String   @unique
  name       String
  bio        String?  @db.Text
  avatar     String?
  coverPhoto String?
  gender     String? // "male" | "female"
  role       Role     @default(USER)
  isVerified Boolean  @default(false)
  isPrivate  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  posts           Post[]
  reactions       Reaction[]
  comments        Comment[]
  notifications   Notification[] @relation("ReceivedNotifications")
  triggeredNotifs Notification[] @relation("TriggeredNotifications")
  following       Follow[]       @relation("Follower")
  followers       Follow[]       @relation("Following")
  savedPosts      SavedPost[]
  healthLogs      HealthLog[]
  periodLogs      PeriodLog[]
  weightLogs      WeightLog[]

  // Phase 3 relations
  conversationParticipants  ConversationParticipant[]
  sentMessages              Message[]                  @relation("SentMessages")
  createdGroups             Group[]
  groupMemberships          GroupMember[]
  groupJoinRequests         GroupJoinRequest[]
  groupInvitesReceived      GroupInvite[]              @relation("GroupInvitesReceived")
  groupInvitesSent          GroupInvite[]              @relation("GroupInvitesSent")
  challengeParticipants     ChallengeParticipant[]
  createdChallenges         Challenge[]
  challengeDayEntries       ChallengeDayEntry[]
  challengeActivities       ChallengeActivity[]
  challengeCommentReactions ChallengeCommentReaction[]
  challengeComments         ChallengeComment[]
  savedChallenges           SavedChallenge[]
  sentChallengeInvites      ChallengeInvite[]          @relation("SentChallengeInvites")
  receivedChallengeInvites  ChallengeInvite[]          @relation("ReceivedChallengeInvites")
  challengeRatings          ChallengeRating[]
  stories                   Story[]
  storyViews                StoryView[]
  storyLikes                StoryLike[]
  storyHighlights           StoryHighlight[]
  reels                     Reel[]
  reelLikes                 ReelLike[]
  reelComments              ReelComment[]
  createdPolls              GroupPoll[]                @relation("CreatedPolls")
  createdEvents             GroupEvent[]               @relation("CreatedEvents")
  groupPollVotes            GroupPollVote[]
  groupEventRsvps           GroupEventRSVP[]
  storyPollVotes            StoryPollVote[]
  storyReactions            StoryReaction[]
  postPollVotes             PostPollVote[]
  postQuizAnswers           PostQuizAnswer[]
  pushSubscriptions         PushSubscription[]

  @@map("users")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Post {
  id           String      @id @default(uuid())
  content      String?     @db.Text
  mediaUrls    String[]
  privacy      PostPrivacy @default(PUBLIC)
  userId       String
  groupId      String?     @map("group_id")
  templateType String?     @map("template_type")
  templateData Json?       @map("template_data")
  healthLogId  String?     @map("health_log_id")
  isDraft      Boolean     @default(false) @map("is_draft")
  scheduledAt  DateTime?   @map("scheduled_at")
  publishedAt  DateTime?   @map("published_at")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reactions   Reaction[]
  comments    Comment[]
  savedBy     SavedPost[]
  healthLog   HealthLog?       @relation(fields: [healthLogId], references: [id])
  poll        PostPoll?
  quizAnswers PostQuizAnswer[]
  hashtags    PostHashtag[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([privacy, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([isDraft, scheduledAt])
  @@map("posts")
}

model PostPoll {
  id               String    @id @default(uuid())
  postId           String    @unique
  question         String
  options          String[]
  isMultipleChoice Boolean   @default(false) @map("is_multiple_choice")
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  post  Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes PostPollVote[]

  @@map("post_polls")
}

model PostPollVote {
  id          String   @id @default(uuid())
  pollId      String
  userId      String
  optionIndex Int      @map("option_index")
  createdAt   DateTime @default(now())

  poll PostPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionIndex])
  @@index([pollId])
  @@map("post_poll_votes")
}

model PostQuizAnswer {
  id            String   @id @default(uuid())
  postId        String
  userId        String
  selectedIndex Int      @map("selected_index")
  isCorrect     Boolean  @default(false) @map("is_correct")
  createdAt     DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@map("post_quiz_answers")
}

model Hashtag {
  id        String   @id @default(uuid())
  name      String   @unique
  postCount Int      @default(0)
  createdAt DateTime @default(now())

  posts PostHashtag[]

  @@index([name])
  @@map("hashtags")
}

model PostHashtag {
  postId    String
  hashtagId String

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@map("post_hashtags")
}

model Reaction {
  id        String       @id @default(uuid())
  type      ReactionType
  postId    String
  userId    String
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("reactions")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  postId    String
  userId    String
  parentId  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([postId, parentId])
  @@map("comments")
}

model SavedPost {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId])
  @@map("saved_posts")
}

model HealthLog {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  type      HealthLogType
  date      DateTime      @default(now())
  data      Json
  score     Int?
  isPublic  Boolean       @default(false) @map("is_public")
  createdAt DateTime      @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts Post[]

  @@index([userId, date(sort: Desc)])
  @@index([userId, type, date(sort: Desc)])
  @@index([userId, isPublic])
  @@map("health_logs")
}

model PeriodLog {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  startDate     DateTime  @map("start_date")
  endDate       DateTime? @map("end_date")
  cycleLength   Int?      @map("cycle_length")
  flowIntensity String?   @map("flow_intensity") // light, medium, heavy
  symptoms      String[]  @default([])
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate(sort: Desc)])
  @@map("period_logs")
}

model WeightLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  weight    Float
  bodyFat   Float?   @map("body_fat")
  waist     Float?
  hips      Float?
  chest     Float?
  arms      Float?
  date      DateTime @default(now())
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date(sort: Desc)])
  @@map("weight_logs")
}

model Notification {
  id         String           @id @default(uuid())
  type       NotificationType
  userId     String
  fromUserId String?
  postId     String?
  commentId  String?
  message    String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user     User  @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)
  fromUser User? @relation("TriggeredNotifications", fields: [fromUserId], references: [id], onDelete: SetNull)

  @@index([userId, type, read, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────

model Conversation {
  id          String   @id @default(uuid())
  isGroup     Boolean  @default(false)
  groupName   String?
  groupAvatar String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  userId         String
  role           String    @default("MEMBER") // "ADMIN" | "MEMBER"
  joinedAt       DateTime  @default(now())
  isMuted        Boolean   @default(false)
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@index([conversationId, role])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String?  @db.Text
  mediaUrl       String?
  sharedPostId   String?
  messageType    String?  @default("text") @map("message_type") // "text" | "story_comment" | "story_quiz_answer" | "story_poll_vote"
  storyId        String?  @map("story_id")
  storyReplyData Json?    @map("story_reply_data") // { storyType, question, options, selectedOption, optionIndex, commentText, textOverlay, correct }
  isDeleted      Boolean  @default(false)
  deletedFor     String[] @default([])
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

// ─────────────────────────────────────────
// GROUPS
// ─────────────────────────────────────────

model Group {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  avatar      String?
  coverPhoto  String?
  type        GroupType @default(PUBLIC)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy    User               @relation(fields: [createdById], references: [id])
  members      GroupMember[]
  posts        Post[]
  challenges   Challenge[]
  joinRequests GroupJoinRequest[]
  invites      GroupInvite[]
  polls        GroupPoll[]
  events       GroupEvent[]

  @@index([type])
  @@map("groups")
}

model GroupMember {
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([role])
  @@index([userId])
  @@index([userId, role])
  @@index([groupId, role])
  @@map("group_members")
}

model GroupJoinRequest {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, status])
  @@map("group_join_requests")
}

model GroupInvite {
  id        String   @id @default(uuid())
  groupId   String
  userId    String // recipient
  invitedBy String // sender
  status    String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User  @relation("GroupInvitesReceived", fields: [userId], references: [id], onDelete: Cascade)
  inviter User  @relation("GroupInvitesSent", fields: [invitedBy], references: [id])

  @@unique([groupId, userId])
  @@index([userId, status])
  @@map("group_invites")
}

model GroupPoll {
  id               String    @id @default(uuid())
  groupId          String
  createdById      String
  question         String
  options          String[] // ["Option A", "Option B", ...]
  isMultipleChoice Boolean   @default(false) @map("is_multiple_choice")
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  group   Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator User            @relation("CreatedPolls", fields: [createdById], references: [id])
  votes   GroupPollVote[]

  @@map("group_polls")
}

model GroupPollVote {
  id          String @id @default(uuid())
  pollId      String
  userId      String
  optionIndex Int    @map("option_index")

  poll GroupPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionIndex])
  @@map("group_poll_votes")
}

model GroupEvent {
  id           String   @id @default(uuid())
  groupId      String
  createdById  String
  title        String
  description  String?  @db.Text
  date         DateTime
  location     String?
  maxAttendees Int?     @map("max_attendees")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group   Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator User             @relation("CreatedEvents", fields: [createdById], references: [id])
  rsvps   GroupEventRSVP[]

  @@index([groupId, date])
  @@map("group_events")
}

model GroupEventRSVP {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  status    String   @default("GOING") // GOING, MAYBE, NOT_GOING
  createdAt DateTime @default(now())

  event GroupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("group_event_rsvps")
}

// ─────────────────────────────────────────
// CHALLENGES
// ─────────────────────────────────────────

model Challenge {
  id          String               @id @default(uuid())
  title       String
  description String               @db.Text
  type        ChallengeType
  groupId     String?
  createdById String
  startDate   DateTime
  endDate     DateTime
  entryFee    Float?
  prize       String?
  goalTarget  Int? // e.g. 50
  goalUnit    String? // e.g. "km", "minutes", "sessions"
  category    ChallengeCategory?   @default(GENERAL)
  difficulty  ChallengeDifficulty? @default(BEGINNER)
  dayCount    Int                  @default(30)
  milestones  Json? // [{ name: "Bronze", threshold: 25, icon: "🥉" }, ...]
  templateId  String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  group        Group?                 @relation(fields: [groupId], references: [id])
  createdBy    User                   @relation(fields: [createdById], references: [id])
  participants ChallengeParticipant[]
  dayEntries   ChallengeDayEntry[]
  activities   ChallengeActivity[]
  comments     ChallengeComment[]
  savedBy      SavedChallenge[]
  invites      ChallengeInvite[]
  template     ChallengeTemplate?     @relation(fields: [templateId], references: [id])
  ratings      ChallengeRating[]
  dayPlans     ChallengeDayPlan[]

  @@index([category])
  @@index([difficulty])
  @@index([isActive, createdAt(sort: Desc)])
  @@map("challenges")
}

model ChallengeParticipant {
  challengeId        String
  userId             String
  score              Int       @default(0)
  rank               Int?
  completed          Boolean   @default(false)
  completedAt        DateTime?
  totalValue         Float     @default(0)
  matchedValue       Float?    // for goal-based challenges (total accumulated)
  joinedAt           DateTime  @default(now())
  currentDayNumber   Int       @default(1) @map("current_day_number")
  achievedMilestones Json? // ["Bronze", "Silver"]
  beforePhoto        String? // dedicated before photo URL
  afterPhoto         String? // dedicated after photo URL

  challenge  Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayEntries ChallengeDayEntry[]

  @@id([challengeId, userId])
  @@index([userId])
  @@index([challengeId, completed])
  @@index([userId, completed])
  @@map("challenge_participants")
}

model ChallengeTemplate {
  id          String             @id @default(uuid())
  title       String
  description String             @db.Text
  type        ChallengeType
  category    ChallengeCategory? @default(GENERAL)
  goalTarget  Int?
  goalUnit    String?
  duration    Int // default days
  milestones  Json? // default milestone definitions
  isOfficial  Boolean            @default(false)
  timesUsed   Int                @default(0)
  createdAt   DateTime           @default(now())

  challenges Challenge[]

  @@map("challenge_templates")
}

model ChallengeDayPlan {
  id          String   @id @default(uuid())
  challengeId String
  dayNumber   Int
  title       String?
  description String?  @db.Text
  tips        String?  @db.Text
  mediaUrls   String[]
  duration    Int? // expected minutes to complete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, dayNumber])
  @@index([challengeId, dayNumber])
  @@map("challenge_day_plans")
}

model ChallengeComment {
  id          String   @id @default(uuid())
  challengeId String
  userId      String
  content     String   @db.Text
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge                  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    ChallengeComment?          @relation("ChallengeCommentReplies", fields: [parentId], references: [id])
  replies   ChallengeComment[]         @relation("ChallengeCommentReplies")
  reactions ChallengeCommentReaction[]

  @@index([challengeId, createdAt(sort: Desc)])
  @@map("challenge_comments")
}

model ChallengeCommentReaction {
  id        String       @id @default(uuid())
  commentId String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  comment ChallengeComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, type])
  @@index([commentId])
  @@map("challenge_comment_reactions")
}

model ChallengeDayEntry {
  id           String    @id @default(uuid())
  challengeId  String
  userId       String
  dayNumber    Int
  completed    Boolean   @default(false)
  notes        String?   @db.Text
  mediaUrls    String[]
  sharedToFeed Boolean   @default(false)
  value        Float?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  challenge   Challenge            @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  participant ChallengeParticipant @relation(fields: [challengeId, userId], references: [challengeId, userId], onDelete: Cascade)

  @@unique([challengeId, userId, dayNumber])
  @@index([challengeId, userId, dayNumber])
  @@index([challengeId, userId, completed])
  @@map("challenge_day_entries")
}

model ChallengeActivity {
  id          String   @id @default(uuid())
  challengeId String
  userId      String
  type        String // JOIN, CHECK_IN, MILESTONE, COMPLETE, COMMENT
  message     String   @db.Text
  metadata    Json? // e.g. { dayNumber: 7, milestoneName: "Bronze" }
  createdAt   DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([challengeId, createdAt(sort: Desc)])
  @@map("challenge_activities")
}

model ChallengeRating {
  challengeId String
  userId      String
  rating      Int // 1-5
  review      String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([challengeId, userId])
  @@index([challengeId])
  @@map("challenge_ratings")
}

model SavedChallenge {
  userId      String
  challengeId String
  savedAt     DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId])
  @@index([userId])
  @@map("saved_challenges")
}

model ChallengeInvite {
  id          String       @id @default(uuid())
  challengeId String
  fromUserId  String
  toUserId    String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  fromUser  User      @relation("SentChallengeInvites", fields: [fromUserId], references: [id])
  toUser    User      @relation("ReceivedChallengeInvites", fields: [toUserId], references: [id])

  @@unique([challengeId, toUserId])
  @@index([toUserId, status])
  @@map("challenge_invites")
}

// ─────────────────────────────────────────
// STORIES
// ─────────────────────────────────────────

model Story {
  id              String   @id @default(uuid())
  userId          String
  type            String   @default("media") // "media" | "text" | "quiz" | "poll"
  privacy         String   @default("friends") // "public" | "friends" | "private"
  mediaUrl        String? // nullable — null for text/quiz/poll stories
  mediaType       String? // nullable — "image" or "video", null for text/quiz/poll
  duration        Int? // seconds for video
  textOverlay     String?
  textColor       String?  @map("text_color")
  textBgColor     String?  @map("text_bg_color") // background/highlight behind text overlay
  textFontSize    Int?     @map("text_font_size")
  textFontWeight  String?  @map("text_font_weight")
  textPosition    String?  @default("center") @map("text_position") // "top" | "center" | "bottom"
  backgroundColor String?  @map("background_color")
  stickerData     Json?    @map("sticker_data") // { type: "quiz"|"poll", question: "...", options: [...], correctOptionIndex: N }
  expiresAt       DateTime // 24 hours after creation
  createdAt       DateTime @default(now())

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  views          StoryView[]
  likes          StoryLike[]
  highlightItems StoryHighlightItem[]
  pollVotes      StoryPollVote[]
  reactions      StoryReaction[]

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("stories")
}

model StoryReaction {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([userId, storyId])
  @@map("story_reactions")
}

model StoryPollVote {
  id          String   @id @default(uuid())
  storyId     String
  userId      String
  optionIndex Int      @map("option_index")
  createdAt   DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_poll_votes")
}

model StoryView {
  storyId  String
  userId   String
  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@index([userId])
  @@map("story_views")
}

model StoryLike {
  storyId   String
  userId    String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@index([userId])
  @@map("story_likes")
}

model StoryHighlight {
  id        String   @id @default(uuid())
  userId    String
  title     String
  coverUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items StoryHighlightItem[]

  @@map("story_highlights")
}

model StoryHighlightItem {
  id          String   @id @default(uuid())
  highlightId String
  storyId     String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  highlight StoryHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  story     Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([highlightId, order])
  @@map("story_highlight_items")
}

// ─────────────────────────────────────────
// REELS
// ─────────────────────────────────────────

model Reel {
  id           String   @id @default(uuid())
  videoUrl     String
  caption      String?  @db.Text
  thumbnailUrl String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    ReelLike[]
  comments ReelComment[]

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("reels")
}

model ReelLike {
  id     String @id @default(uuid())
  reelId String
  userId String

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@map("reel_likes")
}

model ReelComment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reelId, createdAt(sort: Desc)])
  @@map("reel_comments")
}

// ─────────────────────────────────────────
// PUSH NOTIFICATIONS
// ─────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────
// NEWS
// ─────────────────────────────────────────

model NewsArticle {
  id          String   @id @default(uuid())
  title       String
  source      String // e.g., "WHO", "CDC", "Healthline"
  url         String
  imageUrl    String?
  category    String // fitness, nutrition, mental_health, general
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([category, publishedAt(sort: Desc)])
  @@map("news_articles")
}
